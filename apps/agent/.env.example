# Go local agent
SELFSTUDIO_AGENT_HOST=127.0.0.1
SELFSTUDIO_AGENT_PORT=8080
# Prefer an absolute path or set this from scripts to the repository root local-data directory.
SELFSTUDIO_LOCAL_DATA_DIR=../../local-data
# Local-only operator gate. Replace this placeholder on each admin PC.
SELFSTUDIO_AUTH_PIN=change-this-local-pin
